.idea/
.vscode/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
.apt_generated/
.factorypath/

# Logs & debug files
*.log
*.txt
build*.txt
test*.txt
*_output.txt
backend/uploads/

# ======================
# Java / Spring Boot
# ======================
target/
*.jar
*.war
*.class

# ======================
# Angular / Node
# ======================
node_modules/
dist/
.angular/
coverage/

# ======================
# Python
# ======================
venv/
__pycache__/
*.pyc

# ======================
# Environment variables
# ======================
.env
.env.*
!.env.example

# ======================
# Machine Learning
# ======================
*.joblib
*.pkl

# (optional) datasets → only ignore if large
# *.csv

# ======================
