# ── Kaggle credentials (REQUIRED to download Gemma weights) ──────────────────
# Get these from: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Keras backend (DO NOT CHANGE — uses PyTorch for GPU on Windows) ───────────
KERAS_BACKEND=torch

# ── Model selection ───────────────────────────────────────────────────────────
# Options:
#   gemma_instruct_2b_en   (~5 GB,  faster, less powerful)
#   gemma_instruct_7b_en   (~17 GB, slower, more powerful)
#   gemma2_instruct_2b_en  (~5 GB,  Gemma 2 — best small model)
GEMMA_PRESET=gemma_instruct_2b_en

# ── Generation config ─────────────────────────────────────────────────────────
# Maximum new tokens to generate per response
MAX_NEW_TOKENS=300

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
