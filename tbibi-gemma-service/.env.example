# ── HuggingFace credentials (REQUIRED to download Gemma weights) ───────────────
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_hugging_face_token_here
# ── Model selection ───────────────────────────────────────────────────────────
# Default is Google's Gemma 2 2B Instruct model
GEMMA_MODEL_ID=google/gemma-2-2b-it

# ── Generation config ─────────────────────────────────────────────────────────
# Maximum new tokens to generate per response
MAX_NEW_TOKENS=300
TEMPERATURE=0.4

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
