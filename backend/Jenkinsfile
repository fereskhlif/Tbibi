pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk   'JDK17'
    }

    environment {
        // ─── Credentials (configurer dans Jenkins > Manage Credentials) ───
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')

        // ─── Docker ──────────────────────────────────────────────────────
        DOCKER_IMAGE = "${DOCKERHUB_CREDENTIALS_USR}/tbibi-backend_test"
        DOCKER_TAG   = "${BUILD_NUMBER}"

        // ─── GitHub ──────────────────────────────────────────────────────
        GIT_REPO   = 'https://github.com/fereskhlif/Esprit-PIDEV_SE-4SE2-2526-Tbibi.git'
        GIT_BRANCH = 'yassine_pipeline_test'

        // ─── Kubernetes ──────────────────────────────────────────────────
        KUBE_NAMESPACE       = 'tbibi'
        MONITORING_NAMESPACE = 'monitoring'
    }

    stages {

        // ═══════════════════════════════════════════════════════════════
        // 1. RÉCUPÉRATION DU CODE SOURCE
        // ═══════════════════════════════════════════════════════════════
        stage('Git Checkout') {
            steps {
                echo '📥 Récupération du code source depuis GitHub...'
                git branch: "${GIT_BRANCH}",
                    url:    "${GIT_REPO}"
            }
        }

        // ═══════════════════════════════════════════════════════════════
        // 2. COMPILATION MAVEN
        // ═══════════════════════════════════════════════════════════════
        stage('Compilation Maven') {
            steps {
                echo '🔨 Compilation du backend Spring Boot...'
                dir('backend') {
                    sh 'mvn clean compile -DskipTests'
                }
            }
        }

        // ═══════════════════════════════════════════════════════════════
        // 3. EXÉCUTION DES TESTS UNITAIRES
        // ═══════════════════════════════════════════════════════════════
        stage('Tests Unitaires') {
            steps {
                echo '🧪 Exécution des tests unitaires...'
                dir('backend') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    dir('backend') {
                        junit allowEmptyResults: true,
                             testResults: '**/target/surefire-reports/*.xml'
                    }
                }
            }
        }

        // ═══════════════════════════════════════════════════════════════
        // 4. CRÉATION DE L'ARTIFACT (JAR)
        // ═══════════════════════════════════════════════════════════════
        stage('Package JAR') {
            steps {
                echo '📦 Création du fichier JAR...'
                dir('backend') {
                    sh 'mvn package -DskipTests'
                }
            }
            post {
                success {
                    dir('backend') {
                        archiveArtifacts artifacts: 'target/*.jar',
                                         fingerprint: true
                    }
                }
            }
        }

        // ═══════════════════════════════════════════════════════════════
        // 5. CONSTRUCTION DE L'IMAGE DOCKER
        // ═══════════════════════════════════════════════════════════════
        stage('Docker Build') {
            steps {
                echo '🐳 Construction de l\'image Docker...'
                dir('backend') {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                    sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest"
                }
            }
        }

        // ═══════════════════════════════════════════════════════════════
        // 6. PUSH VERS DOCKER HUB
        // ═══════════════════════════════════════════════════════════════
        stage('Push Docker Hub') {
            steps {
                echo '🚀 Publication de l\'image sur Docker Hub...'
                sh 'echo $DOCKERHUB_CREDENTIALS_PSW | docker login -u $DOCKERHUB_CREDENTIALS_USR --password-stdin'
                sh "docker push ${DOCKER_IMAGE}:${DOCKER_TAG}"
                sh "docker push ${DOCKER_IMAGE}:latest"
            }
        }

        /* 
        // ═══════════════════════════════════════════════════════════════ 
        // 7. DÉPLOIEMENT SUR KUBERNETES (kubeadm) 
        // ═══════════════════════════════════════════════════════════════ 
        stage('Déploiement Kubernetes') { 
            steps { 
                echo '☸️ Déploiement sur le cluster Kubernetes...' 
 
                // Créer le namespace 
                sh "kubectl create namespace ${KUBE_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -" 
 
                // Injecter l'image Docker dans le manifest 
                sh "sed -i 's|BACKEND_IMAGE_PLACEHOLDER|${DOCKER_IMAGE}:${DOCKER_TAG}|g' k8s/backend-deployment.yaml" 
 
                // Déployer MySQL 
                sh "kubectl apply -f k8s/mysql-deployment.yaml -n ${KUBE_NAMESPACE}" 
                sh "kubectl rollout status deployment/tbibi-mysql -n ${KUBE_NAMESPACE} --timeout=120s" 
 
                // Déployer le Backend 
                sh "kubectl apply -f k8s/backend-deployment.yaml -n ${KUBE_NAMESPACE}" 
                sh "kubectl rollout status deployment/tbibi-backend -n ${KUBE_NAMESPACE} --timeout=180s" 
            } 
        } 
 
        // ═══════════════════════════════════════════════════════════════ 
        // 8. DÉPLOIEMENT DU MONITORING (Prometheus + Grafana) 
        // ═══════════════════════════════════════════════════════════════ 
        stage('Déploiement Monitoring') { 
            steps { 
                echo '📊 Déploiement de Prometheus & Grafana...' 
 
                // Créer le namespace monitoring 
                sh "kubectl create namespace ${MONITORING_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -" 
 
                // Déployer Prometheus & Grafana 
                sh 'kubectl apply -f k8s/monitoring/prometheus.yaml' 
                sh 'kubectl apply -f k8s/monitoring/grafana.yaml' 
 
                // Vérifier les déploiements 
                sh "kubectl rollout status deployment/prometheus -n ${MONITORING_NAMESPACE} --timeout=120s" 
                sh "kubectl rollout status deployment/grafana -n ${MONITORING_NAMESPACE} --timeout=120s" 
 
                echo '📊 Prometheus → NodePort 30090' 
                echo '📊 Grafana   → NodePort 30030 (admin/admin)' 
            } 
        } 
        */   //  CLOSE COMMENT HERE (ONLY for stages 7 & 8)

    }   //  end stages

    post { 
        always { 
            sh 'docker logout || true' 
            sh "docker rmi ${DOCKER_IMAGE}:${DOCKER_TAG} || true" 
            sh "docker rmi ${DOCKER_IMAGE}:latest || true" 
            cleanWs() 
        } 
        success { 
            echo ' Pipeline CI/CD Backend exécuté avec succès !' 
        } 
        failure { 
            echo ' Le pipeline CI/CD Backend a échoué !' 
        } 
    }    THIS MUST NOT BE COMMENTED

}    end pipeline
