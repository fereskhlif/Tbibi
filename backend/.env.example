# ========================================
# TBIBI Backend Environment Variables
# ========================================
# Copier ce fichier vers .env et remplir les valeurs
# ========================================

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/tbib?createDatabaseIfNotExist=true&useUnicode=true&useJDBCCompliantTimezoneShift=true&useLegacyDatetimeCode=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=

# JWT Security (IMPORTANT: Changer cette valeur en production!)
JWT_SECRET=YOUR_SECRET_KEY_HERE_CHANGE_IN_PRODUCTION
JWT_EXPIRATION_MS=3600000

# Google OAuth2 (Obtenir depuis Google Cloud Console)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# Notification Settings
LAB_NOTIFICATION_DELAY_MINUTES=0
